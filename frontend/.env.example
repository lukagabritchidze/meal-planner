# Base URL of the Spring Boot backend (no trailing slash, no /api suffix).
# Local development leaves this unset and falls back to http://localhost:8080.
# In production (Vercel), set this to your Render backend URL, e.g.:
#   VITE_API_BASE_URL=https://your-app.onrender.com
VITE_API_BASE_URL=http://localhost:8080
